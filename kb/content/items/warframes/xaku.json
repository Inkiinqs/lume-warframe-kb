                                        },
                                        {
                                            "name":  "Grasp Of Lohk",
                                            "description":  "Void Tendrils steal weapons from nearby enemies to use as your own floating, auto-targeting armament. Damage output increases based on enemy level. The number of weapons grabbed also determines the damage multiplier for The Lost: Deny\u0027s Void beam.",
                                            "uniqueName":  "/Lotus/Powersuits/BrokenFrame/Abilities/BrokenGraspAbility",
                                            "imageName":  "BrokenFrameTendrilGrasp.png"
                                        },
                                        {
                                            "name":  "The Lost",
                                            "description":  "Cycle through a trio of lost Warframe powers. Accuse manifests a Void fissure to corrupt enemies into allies. Gaze grasps targets in Void tendrils that capture damage and inflict it when the target is released. Deny annihilates with a beam of Void energy, wiping Sentient resistances.",
                                            "uniqueName":  "/Lotus/Powersuits/BrokenFrame/Abilities/BrokenEmbraceAbility",
                                            "imageName":  "BrokenFrameEmbraceTheFallen.png"
                                        },
                                        {
                                            "name":  "The Vast Untime",
                                            "description":  "Temporarily shed the outer pieces of Xaku in a destructive blast, then stalk the battlefield in a new, swifter skeletal form. Enemies damaged by the body shrapnel are rendered weaker to \u003cDT_RADIANT_COLOR\u003eVoid Damage. Xaku\u0027s other active abilities\u0027 duration is frozen in time and resumes once The Vast Untime expires.",
                                            "uniqueName":  "/Lotus/Powersuits/BrokenFrame/Abilities/BrokenDestructAbility",
                                            "imageName":  "BrokenFrameSelfDestruct.png"
                                        }
                                    ],
