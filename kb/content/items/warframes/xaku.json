                                        {
                                            "name":  "Xata\u0027s Whisper",
                                            "description":  "Wield \u003cDT_RADIANT_COLOR\u003eVoid Damage for all attacks from equipped weapons when activated.",
                                            "uniqueName":  "/Lotus/Powersuits/BrokenFrame/Abilities/BrokenRotAbility",
