                                        },
                                        {
                                            "name":  "Brightbonnet",
                                            "description":  "Release a rejuvenating mushroom that emits a radial pulse, giving Nokko and his allies’ \u003cENERGY\u003e Energy and applying a buff to Ability Strength that lasts for a short time.",
                                            "uniqueName":  "/Lotus/Powersuits/Nokko/Abilities/NokkoPowerShroomAbility",
                                            "imageName":  "NokkoPower.png"
                                        },
                                        {
                                            "name":  "Reroot",
                                            "description":  "Revert to Sprodling form, spawning orbs that heal Nokko and grant a speed boost. While in this state, Nokko is untargetable and heals gradually.",
                                            "uniqueName":  "/Lotus/Powersuits/Nokko/Abilities/NokkoShrinkAbility",
                                            "imageName":  "NokkoShrink.png"
                                        },
                                        {
                                            "name":  "Sporespring",
                                            "description":  "Unleash a chaotic ballistic mushroom that seeks enemies and bounces explosively off whatever it touches. Contact with any of Nokko’s mushrooms invigorates them, doubling their pulse rate.",
                                            "uniqueName":  "/Lotus/Powersuits/Nokko/Abilities/NokkoLaunchAbility",
                                            "imageName":  "NokkoLaunch.png"
                                        }
                                    ],
                      "passiveDescription":  "Upon receiving fatal damage, Nokko reverts to his Sprodling form and his active mushrooms will glow, reviving Nokko when touched. Orbs spawned will grant a speed boost but not healing. If a glowing mushroom is not reached in time, Nokko will automatically use a self-revive."
