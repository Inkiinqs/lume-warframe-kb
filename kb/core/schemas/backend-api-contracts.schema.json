{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "warframe-kb/backend-api-contracts.schema.json",
  "title": "Warframe KB Backend API Contracts",
  "type": "object",
  "required": [
    "schemaVersion",
    "basePath",
    "endpoints"
  ],
  "properties": {
    "schemaVersion": {
      "const": "backend-api-contracts.v1"
    },
    "description": {
      "type": "string"
    },
    "basePath": {
      "type": "string"
    },
    "endpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "method",
          "path",
          "summary",
          "requestExample",
          "responseExample",
          "implementationAnchor",
          "sourceContracts"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "method": {
            "type": "string",
            "enum": [
              "GET",
              "POST",
              "PUT",
              "PATCH",
              "DELETE"
            ]
          },
          "path": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "requestExample": {
            "type": "string"
          },
          "responseExample": {
            "type": "string"
          },
          "implementationAnchor": {
            "type": "string"
          },
          "sourceContracts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
