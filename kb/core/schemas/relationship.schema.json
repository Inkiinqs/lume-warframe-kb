{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "warframe-kb/relationship.schema.json",
  "title": "Warframe KB Relationship",
  "type": "object",
  "required": [
    "id",
    "type",
    "from",
    "to",
    "summary",
    "sources"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "from": {
      "type": "string"
    },
    "to": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "conditions": {
      "type": "object"
    },
    "values": {
      "type": "object"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "value"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": true
}
