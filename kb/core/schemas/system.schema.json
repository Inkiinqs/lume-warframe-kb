{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "warframe-kb/system.schema.json",
  "title": "Warframe KB System",
  "type": "object",
  "required": [
    "id",
    "name",
    "category",
    "summary",
    "mechanics",
    "sources"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "mechanics": {
      "type": "object",
      "properties": {
        "appliesTo": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stacking": {
          "type": [
            "string",
            "null"
          ]
        },
        "duration": {
          "type": [
            "string",
            "null"
          ]
        },
        "formula": {
          "type": [
            "string",
            "null"
          ]
        },
        "specialRules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "interactions": {
      "type": "object"
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "value"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": true
}
