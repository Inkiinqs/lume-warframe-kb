{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "warframe-kb/entity.schema.json",
  "title": "Warframe KB Entity",
  "type": "object",
  "required": [
    "id",
    "name",
    "category",
    "summary",
    "tags",
    "sources"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "subCategory": {
      "type": [
        "string",
        "null"
      ]
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "stats": {
      "type": "object"
    },
    "mechanics": {
      "type": "object"
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "release": {
      "type": "object"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "value"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": true
}
